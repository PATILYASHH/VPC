NODE_ENV=development
PORT=8001

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vpc
DB_USER=vpc_admin
DB_PASSWORD=change_this

# JWT
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_EXPIRES_IN=24h

# Initial admin (used by seed-admin.js)
VPC_ADMIN_USERNAME=admin
VPC_ADMIN_EMAIL=admin@example.com
VPC_ADMIN_PASSWORD=change_this

# Optional features
ENABLE_IP_RESTRICTION=false
FRONTEND_URL=http://localhost:5173

# Backup directory
BACKUP_DIR=/var/backups/vpc

# Log file paths
LOG_PATH_ERP=/var/log/erp/app.log
LOG_PATH_NGINX_ACCESS=/var/log/nginx/access.log
LOG_PATH_NGINX_ERROR=/var/log/nginx/error.log
