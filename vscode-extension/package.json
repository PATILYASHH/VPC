{
  "name": "vpc-sync",
  "displayName": "VPC Sync - BanaDB Schema Management",
  "description": "Git-like schema sync for BanaDB projects. Pull & push database migrations directly from VS Code.",
  "publisher": "vpc-admin",
  "version": "3.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vpcSync",
          "title": "VPC Sync",
          "icon": "$(database)"
        }
      ]
    },
    "views": {
      "vpcSync": [
        {
          "id": "vpcSync.syncActions",
          "name": "Sync",
          "type": "webview"
        },
        {
          "id": "vpcSync.config",
          "name": "Connection",
          "type": "webview",
          "visibility": "collapsed"
        },
        {
          "id": "vpcSync.pullRequests",
          "name": "Pull Requests"
        },
        {
          "id": "vpcSync.history",
          "name": "History"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "vpcSync.pullRequests",
        "contents": "Not connected.\n[Configure Connection](command:vpcSync.configure)",
        "when": "!config.vpcSync.serverUrl"
      },
      {
        "view": "vpcSync.history",
        "contents": "Not connected.\n[Configure Connection](command:vpcSync.configure)",
        "when": "!config.vpcSync.serverUrl"
      }
    ],
    "commands": [
      {
        "command": "vpcSync.configure",
        "title": "VPC Sync: Configure Connection",
        "icon": "$(gear)"
      },
      {
        "command": "vpcSync.pull",
        "title": "VPC Sync: Pull Schema Changes",
        "icon": "$(cloud-download)"
      },
      {
        "command": "vpcSync.push",
        "title": "VPC Sync: Push Migration",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "vpcSync.pushAll",
        "title": "VPC Sync: Push All Staged",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "vpcSync.pushFile",
        "title": "Push Migration",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "vpcSync.pullAll",
        "title": "Pull All Changes",
        "icon": "$(cloud-download)"
      },
      {
        "command": "vpcSync.refresh",
        "title": "VPC Sync: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "vpcSync.status",
        "title": "VPC Sync: Show Status"
      },
      {
        "command": "vpcSync.selectFolder",
        "title": "VPC Sync: Select Output Folder"
      },
      {
        "command": "vpcSync.detectChanges",
        "title": "VPC Sync: Detect Schema Changes",
        "icon": "$(search)"
      },
      {
        "command": "vpcSync.stage",
        "title": "Stage Migration",
        "icon": "$(add)"
      },
      {
        "command": "vpcSync.unstage",
        "title": "Unstage Migration",
        "icon": "$(remove)"
      },
      {
        "command": "vpcSync.stageAll",
        "title": "Stage All Migrations",
        "icon": "$(add)"
      },
      {
        "command": "vpcSync.unstageAll",
        "title": "Unstage All Migrations",
        "icon": "$(remove)"
      },
      {
        "command": "vpcSync.newMigration",
        "title": "VPC Sync: New Migration",
        "icon": "$(new-file)"
      },
      {
        "command": "vpcSync.openFile",
        "title": "Open File",
        "icon": "$(go-to-file)"
      },
      {
        "command": "vpcSync.diffWithRemote",
        "title": "Compare with Remote",
        "icon": "$(diff)"
      },
      {
        "command": "vpcSync.openResourceDiff",
        "title": "Open Diff"
      },
      {
        "command": "vpcSync.showSQL",
        "title": "Show SQL"
      },
      {
        "command": "vpcSync.commitAndPush",
        "title": "VPC Sync: Commit & Push to VPSHUB",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "vpcSync.pullDatabase",
        "title": "VPC Sync: Pull from Database",
        "icon": "$(cloud-download)"
      },
      {
        "command": "vpcSync.compareSchema",
        "title": "VPC Sync: Compare Schema",
        "icon": "$(diff)"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "vpcSync.pushAll",
          "when": "scmProvider == vpc-sync",
          "group": "navigation@1"
        },
        {
          "command": "vpcSync.pullAll",
          "when": "scmProvider == vpc-sync",
          "group": "navigation@2"
        },
        {
          "command": "vpcSync.refresh",
          "when": "scmProvider == vpc-sync",
          "group": "navigation@3"
        },
        {
          "command": "vpcSync.newMigration",
          "when": "scmProvider == vpc-sync",
          "group": "navigation@4"
        },
        {
          "command": "vpcSync.detectChanges",
          "when": "scmProvider == vpc-sync",
          "group": "1_sync"
        },
        {
          "command": "vpcSync.configure",
          "when": "scmProvider == vpc-sync",
          "group": "2_config"
        }
      ],
      "scm/resourceGroup/context": [
        {
          "command": "vpcSync.stageAll",
          "when": "scmProvider == vpc-sync && scmResourceGroup == newMigrations",
          "group": "inline"
        },
        {
          "command": "vpcSync.unstageAll",
          "when": "scmProvider == vpc-sync && scmResourceGroup == readyToPush",
          "group": "inline"
        },
        {
          "command": "vpcSync.pullAll",
          "when": "scmProvider == vpc-sync && scmResourceGroup == pendingRemote",
          "group": "inline"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "vpcSync.stage",
          "when": "scmProvider == vpc-sync && scmResourceGroup == newMigrations",
          "group": "inline@1"
        },
        {
          "command": "vpcSync.unstage",
          "when": "scmProvider == vpc-sync && scmResourceGroup == readyToPush",
          "group": "inline@1"
        },
        {
          "command": "vpcSync.pushFile",
          "when": "scmProvider == vpc-sync && scmResourceGroup == readyToPush",
          "group": "inline@2"
        },
        {
          "command": "vpcSync.openFile",
          "when": "scmProvider == vpc-sync && scmResourceGroup != pendingRemote",
          "group": "inline@3"
        },
        {
          "command": "vpcSync.diffWithRemote",
          "when": "scmProvider == vpc-sync && scmResourceGroup == inReview",
          "group": "inline@2"
        }
      ],
      "view/title": [
        {
          "command": "vpcSync.commitAndPush",
          "when": "view == vpcSync.syncActions",
          "group": "navigation@1"
        },
        {
          "command": "vpcSync.pullDatabase",
          "when": "view == vpcSync.syncActions",
          "group": "navigation@2"
        },
        {
          "command": "vpcSync.compareSchema",
          "when": "view == vpcSync.syncActions",
          "group": "navigation@3"
        },
        {
          "command": "vpcSync.refresh",
          "when": "view =~ /vpcSync/",
          "group": "navigation@4"
        },
        {
          "command": "vpcSync.configure",
          "when": "view =~ /vpcSync/ && view != vpcSync.syncActions",
          "group": "navigation@5"
        }
      ]
    },
    "keybindings": [
      {
        "command": "vpcSync.pushAll",
        "key": "ctrl+shift+enter",
        "mac": "cmd+shift+enter",
        "when": "scmProvider == vpc-sync"
      },
      {
        "command": "vpcSync.newMigration",
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+n"
      }
    ],
    "configuration": {
      "title": "VPC Sync",
      "properties": {
        "vpcSync.serverUrl": {
          "type": "string",
          "default": "",
          "description": "BanaDB project API URL (e.g. http://server:8001/api/bana/v1/my-project)"
        },
        "vpcSync.apiKey": {
          "type": "string",
          "default": "",
          "description": "Pull API key (starts with bana_pull_)"
        },
        "vpcSync.outputFolder": {
          "type": "string",
          "default": "./migrations",
          "description": "Output folder for migration files (relative to workspace root)"
        },
        "vpcSync.autoRefreshInterval": {
          "type": "number",
          "default": 30,
          "description": "Auto-refresh interval in seconds (0 to disable)"
        },
        "vpcSync.autoPull": {
          "type": "boolean",
          "default": false,
          "description": "Automatically pull remote schema changes on refresh"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
